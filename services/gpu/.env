#---------GPU Service-----------------

GPU_SERVICE_URL=http://127.0.0.1:5050

GPU_EMBED_MODEL=MINILM
GPU_FLAN_T5_DIR=E:\emtac\models\llm\flan_t5_large\models--google--flan-t5-large\snapshots\0613663d0d48ea86ba8cb3d7a44f0f65dc596a2a

GPU_MAX_GEN_MODELS=1

GPU_SERVICE_ARTIFACT_ROOT=E:\emtac\services\gpu\artifacts


# -------------------------------------------------
# VLM runtime
# -------------------------------------------------

# Maximum images sent to the VLM in one inference batch
# Vision models rarely scale well beyond 2–3 images
VLM_BATCH_PAGES=1

# Token limit for markdown extraction
# 256 is usually enough for a PDF page
VLM_MAX_NEW_TOKENS=192


# -------------------------------------------------
# PDF pipeline
# -------------------------------------------------

# Rasterization resolution
# 120–150 DPI is the sweet spot for VLM extraction
PDF_RENDER_DPI=120

# Pages processed in a pipeline window
PDF_WINDOW_PAGES=4

# CPU workers for page rendering
PDF_CPU_WORKERS=4

# Windows prefetched ahead of GPU processing
PDF_PREFETCH_WINDOWS=3

# Save rendered page images for debugging / reuse
PDF_SAVE_RENDERED_IMAGES=true
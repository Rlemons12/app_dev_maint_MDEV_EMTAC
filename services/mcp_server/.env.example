COORDINATOR_MCP_SERVER_NAME=EMTAC MCP Coordinator

POSTGRES_MCP_ENABLED=true
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DEFAULT_DB=emtac
POSTGRES_DEFAULT_SCHEMA=public
POSTGRES_MAINTENANCE_DB=postgres

POSTGRES_ADMIN_USER=postgres
POSTGRES_ADMIN_PASSWORD=change_me
POSTGRES_READ_USER=emtac_read
POSTGRES_READ_PASSWORD=change_me
POSTGRES_WRITE_USER=emtac_write
POSTGRES_WRITE_PASSWORD=change_me

MCP_TRANSPORT=stdio
MCP_HTTP_HOST=127.0.0.1
MCP_HTTP_PORT=8000

MAX_READ_ROWS=100

FILESYSTEM_MCP_ENABLED=false
FILESYSTEM_MCP_COMMAND=
FILESYSTEM_MCP_ARGS=

GIT_MCP_ENABLED=false
GIT_MCP_COMMAND=
GIT_MCP_ARGS=

GITHUB_MCP_ENABLED=false
GITHUB_MCP_COMMAND=
GITHUB_MCP_ARGS=

GRAFANA_MCP_ENABLED=false
GRAFANA_MCP_COMMAND=.venv\Scripts\mcp-grafana.exe
GRAFANA_MCP_ARGS=
GRAFANA_MCP_ENV_VARS=GRAFANA_URL,GRAFANA_SERVICE_ACCOUNT_TOKEN
GRAFANA_URL=http://localhost:3000
GRAFANA_SERVICE_ACCOUNT_TOKEN=change_me
GRAFANA_SERVICE_ACCOUNT_NAME=mcp-grafana-readwrite
GRAFANA_SERVICE_ACCOUNT_ROLE=Editor
GRAFANA_SERVICE_ACCOUNT_TOKEN_SECONDS_TO_LIVE=604800

BROWSER_MCP_ENABLED=false
BROWSER_MCP_COMMAND=
BROWSER_MCP_ARGS=


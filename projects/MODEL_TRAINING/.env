
# E:\emtac\dev_env\.env
# =========================================
# EMTAC Offline Hugging Face Environment
# =========================================

# Base model and cache locations
HF_HOME=E:\emtac\models
HF_HUB_CACHE=E:\emtac\models\cache

# Offline mode enabled (no network)
TRANSFORMERS_OFFLINE=1
HF_DATASETS_OFFLINE=1

# Suppress symlink warnings on Windows
HF_HUB_DISABLE_SYMLINKS_WARNING=1

# Optional: Enable HF_XET for better Windows file handling
HF_HUB_ENABLE_HF_XET=1

# For compatibility with some huggingface_hub clients
HUGGINGFACE_HUB_CACHE=E:\emtac\models\cache
TRANSFORMERS_CACHE=E:\emtac\models\cache
HF_DATASETS_CACHE=E:\emtac\models\cache



